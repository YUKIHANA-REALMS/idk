<div class="col-6 offset-3 configuration-step d-none" data-step="1">
    <div class="configuration-subtitle">
        {{ 'indium.first_configuration.site_settings'|trans }}
    </div>
    <p class="text-muted text-center mb-4">
        {{ 'indium.first_configuration.site_settings_description'|trans }}
    </p>
    <form data-step="1">
        <div class="form-group">
            <label class="form-control-label required" for="site_url">{{ 'indium.first_configuration.site_url'|trans }}</label>
            <div class="form-widget">
                <input type="url" id="site_url" name="site_url" class="form-control" value="{{ currentSiteUrl }}" required autofocus autocomplete="site_url">
                <div class="form-text">
                    {{ 'indium.first_configuration.site_url_help'|trans }}
                </div>
            </div>
        </div>

        <div class="form-group">
            <label class="form-control-label required" for="site_title">{{ 'indium.first_configuration.site_title'|trans }}</label>
            <div class="form-widget">
                <input type="text" id="site_title" name="site_title" class="form-control" value="" required autofocus autocomplete="site_title">
                <div class="form-text">
                    {{ 'indium.first_configuration.site_title_help'|trans }}
                </div>
            </div>
        </div>

        <div class="form-group">
            <label class="form-control-label required" for="site_locale">{{ 'indium.first_configuration.site_locale'|trans }}</label>
            <div class="form-widget">
                <select id="site_locale" name="site_locale" class="form-control" required>
                    {% for languageCode, language in availableLanguages %}
                        <option value="{{ languageCode|lower }}" {% if languageCode|lower == 'en' %}selected{% endif %}>{{ language }}</option>
                    {% endfor %}
                </select>
                <div class="form-text">
                    {{ 'indium.first_configuration.site_locale_help'|trans }}
                </div>
            </div>
        </div>

        <div class="form-group">
            <div class="form-check">
                <input
                    type="checkbox"
                    id="telemetry_consent"
                    name="telemetry_consent"
                    class="form-check-input"
                    value="1"
                    checked>
                <label class="form-check-label" for="telemetry_consent">
                    {{ 'indium.first_configuration.telemetry_consent'|trans }}
                </label>
                <div class="form-text text-muted">
                    <small>{{ 'indium.first_configuration.telemetry_consent_help'|trans }}</small>
                </div>
            </div>
        </div>

        <div class="form-group">
            <button type="submit" class="btn primary btn-lg btn-block float-end mb-2">{{ 'indium.first_configuration.next'|trans }}</button>
        </div>
    </form>
</div>