{% extends 'layout/base.html.twig' %}

{% set hero = landingPage.hero|default({}) %}
{% set features = landingPage.features|default({}) %}
{% set products = landingPage.products|default({}) %}
{% set cta = landingPage.cta|default({}) %}

{% block body %}
    {# Hero section #}
    <section class="lp-hero" style="
        background: {% if hero.background_type|default('color') == 'color' %}{{ hero.background_color|default('#000000') }}{% elseif hero.background_type == 'image' %}url('{{ hero.background_image }}') center/cover no-repeat{% elseif hero.background_type == 'video' %}#000000{% endif %};
        color: {{ hero.text_color|default('#ffffff') }};
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding-top: 80px;
    ">
        {% if hero.background_type|default('') == 'video' and hero.background_video|default('') %}
        <video autoplay muted loop playsinline class="lp-hero-video" style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;z-index:0;">
            <source src="{{ hero.background_video }}" type="video/mp4">
        </video>
        <div style="position:absolute;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.6);z-index:1;"></div>
        {% endif %}

        <div class="container position-relative" style="z-index:2;">
            <div class="row justify-content-center text-center">
                <div class="col-lg-8">
                    <h1 class="lp-hero-title" style="font-size: clamp(3rem, 8vw, 6rem); font-weight: 900; letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 1.5rem;">
                        {{ hero.title|default(get_title()) }}
                    </h1>
                    <p class="lp-hero-subtitle" style="font-size: 1.25rem; opacity: 0.8; max-width: 600px; margin: 0 auto 2.5rem; line-height: 1.6;">
                        {{ hero.subtitle|default('') }}
                    </p>
                    <div class="d-flex gap-3 justify-content-center flex-wrap">
                        {% for btn in hero.buttons|default([]) %}
                            {% if btn.style|default('filled') == 'filled' %}
                                <a href="{{ btn.url|default('#') }}" class="btn btn-lg px-5 py-3 fw-semibold" style="background: {{ btn.color|default('#4287f5') }}; color: {{ btn.text_color|default('#ffffff') }}; border: 2px solid {{ btn.color|default('#4287f5') }}; border-radius: 12px; font-size: 1.1rem;">
                                    {{ btn.text }}
                                </a>
                            {% else %}
                                <a href="{{ btn.url|default('#') }}" class="btn btn-lg px-5 py-3 fw-semibold" style="background: transparent; color: {{ btn.text_color|default('#ffffff') }}; border: 2px solid {{ btn.text_color|default('#ffffff') }}; border-radius: 12px; font-size: 1.1rem;">
                                    {{ btn.text }}
                                </a>
                            {% endif %}
                        {% endfor %}
                        {% if hero.buttons is not defined or hero.buttons|length == 0 %}
                            {% if app.user %}
                                <a href="{{ path('panel') }}" class="btn btn-lg px-5 py-3 fw-semibold" style="background: #4287f5; color: #fff; border-radius: 12px;">
                                    <i class="fas fa-tachometer-alt me-2"></i>{{ 'indium.landing.nav.dashboard'|trans }}
                                </a>
                            {% else %}
                                <a href="{{ path('app_register') }}" class="btn btn-lg px-5 py-3 fw-semibold" style="background: #4287f5; color: #fff; border-radius: 12px;">
                                    {{ 'indium.landing.nav.get_started'|trans }}
                                </a>
                                <a href="{{ path('app_login') }}" class="btn btn-lg px-5 py-3 fw-semibold" style="background: transparent; color: #fff; border: 2px solid #fff; border-radius: 12px;">
                                    {{ 'indium.landing.nav.login'|trans }}
                                </a>
                            {% endif %}
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# Features section #}
    {% if features.items is defined and features.items|length > 0 %}
    <section class="py-5" style="background: {{ features.background_color|default('#0a0a0a') }}; color: {{ features.text_color|default('#ffffff') }};">
        <div class="container">
            {% if features.title|default('') %}
            <div class="text-center mb-5">
                <h2 class="display-6 fw-bold">{{ features.title }}</h2>
                {% if features.subtitle|default('') %}
                    <p class="mt-3" style="opacity: 0.7; font-size: 1.1rem;">{{ features.subtitle }}</p>
                {% endif %}
            </div>
            {% endif %}
            <div class="row g-4">
                {% for item in features.items %}
                <div class="col-md-4">
                    <div class="lp-feature-card p-4 rounded-4 h-100" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); transition: transform 0.3s, border-color 0.3s;" onmouseover="this.style.transform='translateY(-4px)';this.style.borderColor='{{ item.color|default('#4287f5') }}'" onmouseout="this.style.transform='';this.style.borderColor='rgba(255,255,255,0.08)'">
                        {% if item.image|default('') %}
                            <img src="{{ item.image }}" alt="{{ item.title }}" class="mb-3" style="width:48px;height:48px;object-fit:contain;">
                        {% else %}
                            <div class="mb-3" style="width:48px;height:48px;border-radius:12px;background:{{ item.color|default('#4287f5') }}20;display:flex;align-items:center;justify-content:center;">
                                <i class="fas {{ item.icon|default('fa-star') }}" style="font-size:20px;color:{{ item.color|default('#4287f5') }}"></i>
                            </div>
                        {% endif %}
                        <h5 class="fw-bold">{{ item.title }}</h5>
                        <p style="opacity: 0.7; line-height: 1.6;">{{ item.description }}</p>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>
    {% endif %}

    {# Featured products #}
    {% if products.title is defined and products.title %}
    <section class="py-5" style="background: {{ products.background_color|default('#000000') }}; color: {{ products.text_color|default('#ffffff') }};">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="display-6 fw-bold">{{ products.title }}</h2>
                {% if products.subtitle|default('') %}
                    <p class="mt-3" style="opacity: 0.7; font-size: 1.1rem;">{{ products.subtitle }}</p>
                {% endif %}
            </div>
            {{ include('components/featured-products.html.twig', {
                products: featuredProducts,
                cardStyle: products.card_style|default('rounded'),
                cardRadius: products.card_border_radius|default('16px'),
                cardShadow: products.card_shadow|default(true),
                cardShadowColor: products.card_shadow_color|default('rgba(66,135,245,0.15)'),
                cardShadowBlur: products.card_shadow_blur|default('20px'),
                cardBg: products.card_background|default('#0a0a0a'),
                cardBorder: products.card_border_color|default('#222222'),
                cardHover: products.card_hover|default(true),
                cardHoverScale: products.card_hover_scale|default('1.02'),
                btnText: products.button_text|default('Order Now'),
                btnColor: products.button_color|default('#4287f5'),
                btnTextColor: products.button_text_color|default('#ffffff'),
            }) }}
        </div>
    </section>
    {% else %}
    <section class="py-5" style="background: #000000; color: #ffffff;">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="display-6 fw-bold">{{ 'indium.landing.products.title'|trans }}</h2>
                <div class="mx-auto mt-3 rounded-pill" style="height: 4px; width: 60px; background: #4287f5;"></div>
            </div>
            {{ include('components/featured-products.html.twig', { products: featuredProducts }) }}
        </div>
    </section>
    {% endif %}

    {# CTA section #}
    {% if cta.title is defined and cta.title %}
    <section class="py-5" style="background: {{ cta.background_color|default('#0a0a0a') }}; color: {{ cta.text_color|default('#ffffff') }};">
        <div class="container text-center">
            <h2 class="display-6 fw-bold mb-3">{{ cta.title }}</h2>
            {% if cta.subtitle|default('') %}
                <p class="mb-4" style="opacity: 0.7; font-size: 1.1rem;">{{ cta.subtitle }}</p>
            {% endif %}
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                {% for btn in cta.buttons|default([]) %}
                    {% if btn.style|default('filled') == 'filled' %}
                        <a href="{{ btn.url|default('#') }}" class="btn btn-lg px-5 py-3 fw-semibold" style="background: {{ btn.color|default('#4287f5') }}; color: {{ btn.text_color|default('#ffffff') }}; border: 2px solid {{ btn.color|default('#4287f5') }}; border-radius: 12px;">
                            {{ btn.text }}
                        </a>
                    {% else %}
                        <a href="{{ btn.url|default('#') }}" class="btn btn-lg px-5 py-3 fw-semibold" style="background: transparent; color: {{ btn.text_color|default('#ffffff') }}; border: 2px solid {{ btn.text_color|default('#ffffff') }}; border-radius: 12px;">
                            {{ btn.text }}
                        </a>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    </section>
    {% else %}
        {{ include('components/cta-section.html.twig') }}
    {% endif %}
{% endblock %}
