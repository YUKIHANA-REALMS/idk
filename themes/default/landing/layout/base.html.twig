{% set general = landingPage.general|default({}) %}
{% set navbar = landingPage.navbar|default({}) %}
{% set footer = landingPage.footer|default({}) %}

<!DOCTYPE html>
<html lang="{{ app.request.locale }}" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ general.site_title|default(get_title()) }}{% endblock %}</title>
    {% if general.favicon_url|default('') %}
    <link rel="icon" href="{{ general.favicon_url }}">
    {% else %}
    <link rel="icon" href="{{ get_favicon() }}">
    {% endif %}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    {% block stylesheets %}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <link rel="stylesheet" href="{{ asset('assets/theme/default/css/landing.css') }}">
    {% endblock %}

    <style>
        :root {
            --lp-navbar-bg: {{ navbar.background_color|default('#000000') }};
            --lp-navbar-text: {{ navbar.text_color|default('#ffffff') }};
            --lp-navbar-btn: {{ navbar.button_color|default('#4287f5') }};
        }
        .navbar.lp-custom { background: var(--lp-navbar-bg) !important; }
        .navbar.lp-custom .nav-link { color: var(--lp-navbar-text) !important; }
        .navbar.lp-custom .btn-primary { background: var(--lp-navbar-btn); border-color: var(--lp-navbar-btn); }
        footer.lp-custom { background: {{ footer.background_color|default('#000000') }}; color: {{ footer.text_color|default('#888888') }}; }
    </style>

    {% block head_custom_scripts %}
        {% include 'components/custom_head_scripts.html.twig' %}
    {% endblock %}
</head>
<body class="d-flex flex-column min-vh-100">
    {% block navigation %}
        <nav class="navbar navbar-expand-lg navbar-dark fixed-top lp-custom">
            <div class="container">
                <a class="navbar-brand" href="{{ path('homepage') }}">
                    {% if general.logo_url|default('') %}
                        <img src="{{ general.logo_url }}" alt="{{ general.site_title|default(get_title()) }}" height="40">
                    {% else %}
                        <img src="{{ get_logo() }}" alt="{{ general.site_title|default(get_title()) }}" height="40" class="d-inline-block align-text-top me-2">
                    {% endif %}
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center">
                        {% if navbar.links is defined %}
                            {% for link in navbar.links %}
                                {% if link.is_active|default(true) %}
                                    <li class="nav-item">
                                        <a class="nav-link" href="{{ link.url }}">{{ link.text }}</a>
                                    </li>
                                {% endif %}
                            {% endfor %}
                        {% endif %}

                        {% if navigationButtons is defined %}
                            {% for button in navigationButtons %}
                                {% if button.position == 'right' %}
                                    {{ include('components/nav-button.html.twig', {button: button}) }}
                                {% endif %}
                            {% endfor %}
                        {% else %}
                            {% if app.user %}
                                <li class="nav-item">
                                    <a class="btn btn-primary btn-sm ms-3" href="{{ path('panel') }}">
                                        <i class="fas fa-tachometer-alt me-2"></i>{{ 'indium.landing.nav.dashboard'|trans }}
                                    </a>
                                </li>
                            {% else %}
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('app_login') }}">{{ 'indium.landing.nav.login'|trans }}</a>
                                </li>
                                <li class="nav-item">
                                    <a class="btn btn-primary btn-sm ms-3" href="{{ path('app_register') }}">{{ 'indium.landing.nav.get_started'|trans }}</a>
                                </li>
                            {% endif %}
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>
    {% endblock %}

    <main class="flex-grow-1">
        {% block body %}{% endblock %}
    </main>

    {% block footer %}
        <footer class="lp-custom">
            <div class="container text-center">
                {% if footer.show_logo|default(true) %}
                <div class="mb-4">
                    {% if general.logo_url|default('') %}
                        <img src="{{ general.logo_url }}" alt="{{ general.site_title|default(get_title()) }}" height="30" style="opacity: 0.7;">
                    {% else %}
                        <img src="{{ get_logo() }}" alt="{{ general.site_title|default(get_title()) }}" height="30" style="opacity: 0.7;">
                    {% endif %}
                </div>
                {% endif %}
                {% if footer.links is defined and footer.links|length > 0 %}
                <div class="mb-3">
                    {% for link in footer.links %}
                        <a href="{{ link.url }}" class="mx-2 text-decoration-none" style="color: {{ footer.text_color|default('#888888') }}">{{ link.text }}</a>
                    {% endfor %}
                </div>
                {% endif %}
                <p class="mb-2">&copy; {{ 'now'|date('Y') }} {{ general.site_title|default(get_title()) }}. {{ footer.copyright_text|default('All rights reserved.') }}</p>
                {% if footer.social_links is defined and footer.social_links|length > 0 %}
                <div class="mb-3">
                    {% for social in footer.social_links %}
                        <a href="{{ social.url }}" class="mx-2" target="_blank" style="color: {{ footer.text_color|default('#888888') }}">
                            <i class="fab fa-{{ social.platform }}"></i>
                        </a>
                    {% endfor %}
                </div>
                {% endif %}
                <p class="small" style="opacity: 0.5">{{ 'indium.landing.footer.powered_by'|trans({'%version%': get_app_version()})|raw }}</p>
            </div>
        </footer>
    {% endblock %}

    {% block javascripts %}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    {% endblock %}
</body>
</html>
