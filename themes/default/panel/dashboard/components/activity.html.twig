<div class="card border-0 shadow-sm rounded-3">
    <div class="card-header">
        <div class="d-flex align-items-center">
            <i class="fas fa-history me-2"></i>
            <h5 class="mb-0 fw-semibold">{{ 'indium.dashboard.last_activity'|trans }}</h5>
        </div>
    </div>
    <div class="card-body p-4">
        {% if logs|length > 0 %}
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th class="fw-semibold">
                                <i class="fas fa-bolt me-2" style="color: var(--primary-color);"></i>
                                {{ 'indium.dashboard.action'|trans }}
                            </th>
                            <th class="fw-semibold">
                                <i class="fas fa-globe me-2" style="color: var(--primary-color);"></i>
                                {{ 'indium.dashboard.ip_address'|trans }}
                            </th>
                            <th class="fw-semibold">
                                <i class="fas fa-calendar me-2" style="color: var(--primary-color);"></i>
                                {{ 'indium.dashboard.date'|trans }}
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for log in logs %}
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="me-2">
                                            <i class="fas fa-user-check p-2" style="font-size: 0.75rem; color: var(--primary-color);"></i>
                                        </div>
                                        {{ ('indium.actions.' ~ log.actionId)|trans }}
                                    </div>
                                </td>
                                <td>
                                    <span class="badge">{{ log.ipAddress }}</span>
                                </td>
                                <td>
                                    <small class="text-muted">{{ log.createdAt|app_date }}</small>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="text-center py-4">
                <div class="mx-auto mb-3" style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; background-color: var(--stripe-gray-100); border-radius: 50%;">
                    <i class="fas fa-history text-muted" style="font-size: 1.5rem;"></i>
                </div>
                <h6 class="fw-bold mb-1" style="color: var(--bs-heading-color);">{{ 'indium.dashboard.no_activity'|trans }}</h6>
                <p class="text-muted mb-0 small">{{ 'indium.dashboard.no_activity_description'|trans }}</p>
            </div>
        {% endif %}
    </div>
</div>
