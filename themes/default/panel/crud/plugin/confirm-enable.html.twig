{% extends '@EasyAdmin/layout.html.twig' %}

{% block content_header_wrapper %}
    <div class="dashboard-header rounded-3 p-4 mb-4 mt-4">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <div class="bg-warning rounded-circle me-3">
                        <i class="fas fa-exclamation-triangle p-3 text-white"></i>
                    </div>
                    <div>
                        <h4 class="mb-1 fw-bold">{{ 'indium.crud.plugin.version_mismatch_title'|trans }}</h4>
                        <p class="text-muted mb-0">{{ plugin.displayName }} v{{ plugin.version }}</p>
                    </div>
                </div>
                <div>
                    <a href="{{ cancel_url }}" class="btn btn-outline-secondary">
                        <i class="fa fa-arrow-left me-2"></i>{{ 'indium.crud.plugin.back_to_list'|trans }}
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block main %}
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-4">
            <div class="alert alert-warning mb-4">
                <i class="fa fa-exclamation-triangle me-2"></i>
                <strong>{{ 'indium.crud.plugin.warning'|trans }}</strong>
            </div>

            <p>
                {{ 'indium.crud.plugin.version_mismatch_message'|trans({
                    '%plugin_version%': plugin.indiumMinVersion,
                    '%current_version%': current_version
                })|raw }}
            </p>

            <div class="card bg-light mb-4">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <strong>{{ 'indium.crud.plugin.plugin_name'|trans }}:</strong>
                            <code>{{ plugin.displayName }}</code>
                        </div>
                        <div class="col-md-3">
                            <strong>{{ 'indium.crud.plugin.min_indium'|trans }}:</strong>
                            <code>{{ plugin.indiumMinVersion }}</code>
                        </div>
                        <div class="col-md-3">
                            <strong>Indium Panel:</strong>
                            <code>{{ current_version }}</code>
                        </div>
                    </div>
                </div>
            </div>

            <div class="alert alert-danger mb-4">
                <i class="fa fa-exclamation-circle me-2"></i>
                {{ 'indium.crud.plugin.version_mismatch_risk'|trans }}
            </div>

            <div class="d-flex justify-content-between">
                <a href="{{ cancel_url }}" class="btn secondary">
                    <i class="fa fa-times me-2"></i>{{ 'indium.crud.plugin.cancel'|trans }}
                </a>
                <a href="{{ confirm_url }}" class="btn warning">
                    <i class="fa fa-exclamation-triangle me-2"></i>{{ 'indium.crud.plugin.enable_anyway'|trans }}
                </a>
            </div>
        </div>
    </div>
{% endblock %}
