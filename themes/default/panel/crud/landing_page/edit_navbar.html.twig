{% extends '@EasyAdmin/layout.html.twig' %}

{% block content_header_wrapper %}
    <div class="dashboard-header rounded-3 p-4 mb-4 mt-4">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <div class="bg-primary rounded-circle me-3">
                        <i class="fas fa-bars p-3 text-white"></i>
                    </div>
                    <div>
                        <h4 class="mb-1 fw-bold">Edit Navigation Bar</h4>
                        <p class="text-muted mb-0">Configure navigation links and styling</p>
                    </div>
                </div>
                <a href="{{ ea_url({ crudAction: 'index', crudControllerFqcn: 'App\\Core\\Controller\\Panel\\Setting\\LandingPageController' }) }}" class="btn secondary p-3">
                    <i class="fa fa-arrow-left"></i> Back to Sections
                </a>
            </div>
        </div>
    </div>
{% endblock %}

{% block main %}
<form method="post" action="{{ ea_url({ crudAction: 'updateSection', crudControllerFqcn: 'App\\Core\\Controller\\Panel\\Setting\\LandingPageController' }) }}">
    <input type="hidden" name="sectionType" value="{{ section_type }}">

    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header bg-white border-bottom">
            <h5 class="mb-0 fw-bold">Navigation Bar Styling</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Background Color</label>
                    <div class="input-group">
                        <input type="color" name="content[background_color]" class="form-control form-control-color" value="{{ content.background_color|default('#000000') }}">
                        <input type="text" class="form-control" value="{{ content.background_color|default('#000000') }}" oninput="this.previousElementSibling.value=this.value">
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Text Color</label>
                    <div class="input-group">
                        <input type="color" name="content[text_color]" class="form-control form-control-color" value="{{ content.text_color|default('#ffffff') }}">
                        <input type="text" class="form-control" value="{{ content.text_color|default('#ffffff') }}" oninput="this.previousElementSibling.value=this.value">
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Button Color</label>
                    <div class="input-group">
                        <input type="color" name="content[button_color]" class="form-control form-control-color" value="{{ content.button_color|default('#4287f5') }}">
                        <input type="text" class="form-control" value="{{ content.button_color|default('#4287f5') }}" oninput="this.previousElementSibling.value=this.value">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">Navigation Links</h5>
            <button type="button" class="btn btn-sm btn-success" onclick="addNavLink()">
                <i class="fa fa-plus"></i> Add Link
            </button>
        </div>
        <div class="card-body" id="navLinksContainer">
            {% for link in content.links|default([]) %}
            <div class="row g-2 mb-2 nav-link-row">
                <div class="col-md-3">
                    <input type="text" name="links[text][]" class="form-control" value="{{ link.text|default('') }}" placeholder="Link Text">
                </div>
                <div class="col-md-4">
                    <input type="text" name="links[url][]" class="form-control" value="{{ link.url|default('') }}" placeholder="URL">
                </div>
                <div class="col-md-3">
                    <select name="links[is_active][]" class="form-select">
                        <option value="1" {{ link.is_active|default(true) ? 'selected' : '' }}>Visible</option>
                        <option value="0" {{ not (link.is_active|default(true)) ? 'selected' : '' }}>Hidden</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="button" class="btn btn-sm btn-danger w-100" onclick="this.closest('.nav-link-row').remove()">
                        <i class="fa fa-trash"></i>
                    </button>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-body d-flex justify-content-between">
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="isEnabled" id="isEnabled" {{ section.isEnabled ? 'checked' : '' }}>
                <label class="form-check-label fw-semibold" for="isEnabled">Section Enabled</label>
            </div>
            <button type="submit" class="btn primary px-4">
                <i class="fa fa-save me-2"></i>Save Changes
            </button>
        </div>
    </div>
</form>

<script>
function addNavLink() {
    const container = document.getElementById('navLinksContainer');
    const row = document.createElement('div');
    row.className = 'row g-2 mb-2 nav-link-row';
    row.innerHTML = `
        <div class="col-md-3"><input type="text" name="links[text][]" class="form-control" placeholder="Link Text"></div>
        <div class="col-md-4"><input type="text" name="links[url][]" class="form-control" placeholder="URL"></div>
        <div class="col-md-3"><select name="links[is_active][]" class="form-select"><option value="1">Visible</option><option value="0">Hidden</option></select></div>
        <div class="col-md-2"><button type="button" class="btn btn-sm btn-danger w-100" onclick="this.closest('.nav-link-row').remove()"><i class="fa fa-trash"></i></button></div>
    `;
    container.appendChild(row);
}
</script>
{% endblock %}
