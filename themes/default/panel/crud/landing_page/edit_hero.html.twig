{% extends '@EasyAdmin/layout.html.twig' %}

{% block content_header_wrapper %}
    <div class="dashboard-header rounded-3 p-4 mb-4 mt-4">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <div class="bg-primary rounded-circle me-3">
                        <i class="fas fa-star p-3 text-white"></i>
                    </div>
                    <div>
                        <h4 class="mb-1 fw-bold">Edit Hero Section</h4>
                        <p class="text-muted mb-0">Configure the main hero/banner section</p>
                    </div>
                </div>
                <a href="{{ ea_url({ crudAction: 'index', crudControllerFqcn: 'App\\Core\\Controller\\Panel\\Setting\\LandingPageController' }) }}" class="btn secondary p-3">
                    <i class="fa fa-arrow-left"></i> Back to Sections
                </a>
            </div>
        </div>
    </div>
{% endblock %}

{% block main %}
<form method="post" action="{{ ea_url({ crudAction: 'updateSection', crudControllerFqcn: 'App\\Core\\Controller\\Panel\\Setting\\LandingPageController' }) }}">
    <input type="hidden" name="sectionType" value="{{ section_type }}">

    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header bg-white border-bottom">
            <h5 class="mb-0 fw-bold">Hero Content</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label fw-semibold">Title</label>
                    <input type="text" name="content[title]" class="form-control fs-4" value="{{ content.title|default('') }}" placeholder="Your Panel Name">
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Subtitle</label>
                    <textarea name="content[subtitle]" class="form-control" rows="3" placeholder="A short description">{{ content.subtitle|default('') }}</textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header bg-white border-bottom">
            <h5 class="mb-0 fw-bold">Background</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Background Type</label>
                    <select name="content[background_type]" class="form-select" onchange="toggleHeroBgType(this.value)">
                        <option value="color" {{ content.background_type|default('color') == 'color' ? 'selected' : '' }}>Solid Color</option>
                        <option value="image" {{ content.background_type|default('') == 'image' ? 'selected' : '' }}>Image</option>
                        <option value="video" {{ content.background_type|default('') == 'video' ? 'selected' : '' }}>Video</option>
                    </select>
                </div>
                <div class="col-md-4 hero-bg-color" {{ content.background_type|default('color') != 'color' ? 'style="display:none"' : '' }}>
                    <label class="form-label fw-semibold">Background Color</label>
                    <div class="input-group">
                        <input type="color" name="content[background_color]" class="form-control form-control-color" value="{{ content.background_color|default('#000000') }}">
                        <input type="text" class="form-control" value="{{ content.background_color|default('#000000') }}">
                    </div>
                </div>
                <div class="col-md-8 hero-bg-image" {{ content.background_type|default('color') != 'image' ? 'style="display:none"' : '' }}>
                    <label class="form-label fw-semibold">Background Image URL</label>
                    <input type="text" name="content[background_image]" class="form-control" value="{{ content.background_image|default('') }}" placeholder="https://example.com/image.jpg">
                </div>
                <div class="col-md-8 hero-bg-video" {{ content.background_type|default('') != 'video' ? 'style="display:none"' : '' }}>
                    <label class="form-label fw-semibold">Background Video URL</label>
                    <input type="text" name="content[background_video]" class="form-control" value="{{ content.background_video|default('') }}" placeholder="https://example.com/video.mp4">
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Text Color</label>
                    <div class="input-group">
                        <input type="color" name="content[text_color]" class="form-control form-control-color" value="{{ content.text_color|default('#ffffff') }}">
                        <input type="text" class="form-control" value="{{ content.text_color|default('#ffffff') }}">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">Hero Buttons</h5>
            <button type="button" class="btn btn-sm btn-success" onclick="addHeroButton()">
                <i class="fa fa-plus"></i> Add Button
            </button>
        </div>
        <div class="card-body" id="heroButtonsContainer">
            {% for btn in content.buttons|default([]) %}
            <div class="row g-2 mb-2 hero-btn-row">
                <div class="col-md-2"><input type="text" name="buttons[text][]" class="form-control" value="{{ btn.text|default('') }}" placeholder="Button Text"></div>
                <div class="col-md-3"><input type="text" name="buttons[url][]" class="form-control" value="{{ btn.url|default('') }}" placeholder="URL"></div>
                <div class="col-md-2"><input type="color" name="buttons[color][]" class="form-control form-control-color" value="{{ btn.color|default('#4287f5') }}"></div>
                <div class="col-md-2"><input type="color" name="buttons[text_color][]" class="form-control form-control-color" value="{{ btn.text_color|default('#ffffff') }}"></div>
                <div class="col-md-2">
                    <select name="buttons[style][]" class="form-select">
                        <option value="filled" {{ btn.style|default('filled') == 'filled' ? 'selected' : '' }}>Filled</option>
                        <option value="outlined" {{ btn.style|default('') == 'outlined' ? 'selected' : '' }}>Outlined</option>
                    </select>
                </div>
                <div class="col-md-1"><button type="button" class="btn btn-sm btn-danger w-100" onclick="this.closest('.hero-btn-row').remove()"><i class="fa fa-trash"></i></button></div>
            </div>
            {% endfor %}
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-body d-flex justify-content-between">
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="isEnabled" id="isEnabled" {{ section.isEnabled ? 'checked' : '' }}>
                <label class="form-check-label fw-semibold" for="isEnabled">Section Enabled</label>
            </div>
            <button type="submit" class="btn primary px-4"><i class="fa fa-save me-2"></i>Save Changes</button>
        </div>
    </div>
</form>

<script>
function toggleHeroBgType(type) {
    document.querySelector('.hero-bg-color').style.display = type === 'color' ? '' : 'none';
    document.querySelector('.hero-bg-image').style.display = type === 'image' ? '' : 'none';
    document.querySelector('.hero-bg-video').style.display = type === 'video' ? '' : 'none';
}
function addHeroButton() {
    const c = document.getElementById('heroButtonsContainer');
    const r = document.createElement('div');
    r.className = 'row g-2 mb-2 hero-btn-row';
    r.innerHTML = `<div class="col-md-2"><input type="text" name="buttons[text][]" class="form-control" placeholder="Text"></div><div class="col-md-3"><input type="text" name="buttons[url][]" class="form-control" placeholder="URL"></div><div class="col-md-2"><input type="color" name="buttons[color][]" class="form-control form-control-color" value="#4287f5"></div><div class="col-md-2"><input type="color" name="buttons[text_color][]" class="form-control form-control-color" value="#ffffff"></div><div class="col-md-2"><select name="buttons[style][]" class="form-select"><option value="filled">Filled</option><option value="outlined">Outlined</option></select></div><div class="col-md-1"><button type="button" class="btn btn-sm btn-danger w-100" onclick="this.closest('.hero-btn-row').remove()"><i class="fa fa-trash"></i></button></div>`;
    c.appendChild(r);
}
</script>
{% endblock %}
