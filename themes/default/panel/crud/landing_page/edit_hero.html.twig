{% extends '@EasyAdmin/layout.html.twig' %}

{% block content_header_wrapper %}
    <div class="dashboard-header rounded-3 p-4 mb-4 mt-4">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <div class="bg-primary rounded-circle me-3">
                        <i class="fas fa-star p-3 text-white"></i>
                    </div>
                    <div>
                        <h4 class="mb-1 fw-bold">Edit Hero Section</h4>
                        <p class="text-muted mb-0">Configure the main hero/banner section with two-column layout</p>
                    </div>
                </div>
                <a href="{{ ea_url({ crudAction: 'index', crudControllerFqcn: 'App\\Core\\Controller\\Panel\\Setting\\LandingPageController' }) }}" class="btn secondary p-3">
                    <i class="fa fa-arrow-left"></i> Back to Sections
                </a>
            </div>
        </div>
    </div>
{% endblock %}

{% block main %}
<form method="post" action="{{ ea_url({ crudAction: 'updateSection', crudControllerFqcn: 'App\\Core\\Controller\\Panel\\Setting\\LandingPageController' }) }}">
    <input type="hidden" name="sectionType" value="{{ section_type }}">

    {# Main Title (Left Column) #}
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header border-bottom">
            <h5 class="mb-0 fw-bold"><i class="fa fa-heading me-2"></i>Main Title (Left Column)</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label fw-semibold">Title</label>
                    <input type="text" name="content[title]" class="form-control fs-4" value="{{ content.title|default('') }}" placeholder="Welcome.">
                    <small class="text-muted">The large heading displayed on the left side. Use a period at the end for the signature style.</small>
                </div>
            </div>
        </div>
    </div>

    {# Search Bar Settings #}
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header border-bottom d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="fa fa-search me-2"></i>Search Bar</h5>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="content[show_search]" id="showSearch" value="1" {{ content.show_search|default(1) ? 'checked' : '' }}>
                <label class="form-check-label fw-semibold" for="showSearch">Show Search Bar</label>
            </div>
        </div>
        <div class="card-body" id="searchBarSettings">
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label fw-semibold">Placeholder Text</label>
                    <input type="text" name="content[search_placeholder]" class="form-control" value="{{ content.search_placeholder|default('Search...') }}" placeholder="Search...">
                </div>
            </div>
        </div>
    </div>

    {# Side Content (Right Column) #}
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header border-bottom">
            <h5 class="mb-0 fw-bold"><i class="fa fa-columns me-2"></i>Side Content (Right Column)</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12">
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" name="content[side_logo_enabled]" id="sideLogoEnabled" value="1" {{ content.side_logo_enabled|default(1) ? 'checked' : '' }}>
                        <label class="form-check-label fw-semibold" for="sideLogoEnabled">Show Side Logo</label>
                    </div>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Side Title</label>
                    <input type="text" name="content[side_title]" class="form-control fs-5" value="{{ content.side_title|default('Landing page.') }}" placeholder="Landing page.">
                    <small class="text-muted">The title displayed on the right column below the logo.</small>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Side Description</label>
                    <textarea name="content[side_description]" class="form-control" rows="3" placeholder="Lorem ipsum dolor sit amet...">{{ content.side_description|default('') }}</textarea>
                    <small class="text-muted">Short description text below the side title.</small>
                </div>
            </div>
        </div>
    </div>

    {# Wave Animation Settings #}
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header border-bottom d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="fa fa-water me-2"></i>Wave Animation</h5>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="content[show_waves]" id="showWaves" value="1" {{ content.show_waves|default(1) ? 'checked' : '' }}>
                <label class="form-check-label fw-semibold" for="showWaves">Show Waves</label>
            </div>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12">
                    <small class="text-muted">Animated concentric wave rings displayed in the center of the hero section. These create the organic contour-line visual effect.</small>
                </div>
            </div>
        </div>
    </div>

    {# Scroll Indicator Settings #}
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header border-bottom d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="fa fa-computer-mouse me-2"></i>Scroll Indicator</h5>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="content[show_scroll_indicator]" id="showScrollIndicator" value="1" {{ content.show_scroll_indicator|default(1) ? 'checked' : '' }}>
                <label class="form-check-label fw-semibold" for="showScrollIndicator">Show Scroll Indicator</label>
            </div>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12">
                    <small class="text-muted">Mouse icon at the bottom center of the hero section indicating users can scroll down.</small>
                </div>
            </div>
        </div>
    </div>

    {# Background Settings #}
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header border-bottom">
            <h5 class="mb-0 fw-bold"><i class="fa fa-fill-drip me-2"></i>Background</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Background Type</label>
                    <select name="content[background_type]" class="form-select" onchange="toggleHeroBgType(this.value)">
                        <option value="color" {{ content.background_type|default('color') == 'color' ? 'selected' : '' }}>Solid Color</option>
                        <option value="image" {{ content.background_type|default('') == 'image' ? 'selected' : '' }}>Image</option>
                        <option value="video" {{ content.background_type|default('') == 'video' ? 'selected' : '' }}>Video</option>
                    </select>
                </div>
                <div class="col-md-4 hero-bg-color" {{ content.background_type|default('color') != 'color' ? 'style="display:none"' : '' }}>
                    <label class="form-label fw-semibold">Background Color</label>
                    <div class="input-group">
                        <input type="color" name="content[background_color]" class="form-control form-control-color" value="{{ content.background_color|default('#000000') }}">
                        <input type="text" class="form-control" value="{{ content.background_color|default('#000000') }}">
                    </div>
                </div>
                <div class="col-md-8 hero-bg-image" {{ content.background_type|default('color') != 'image' ? 'style="display:none"' : '' }}>
                    <label class="form-label fw-semibold">Background Image URL</label>
                    <input type="text" name="content[background_image]" class="form-control" value="{{ content.background_image|default('') }}" placeholder="https://example.com/image.jpg">
                </div>
                <div class="col-md-8 hero-bg-video" {{ content.background_type|default('') != 'video' ? 'style="display:none"' : '' }}>
                    <label class="form-label fw-semibold">Background Video URL</label>
                    <input type="text" name="content[background_video]" class="form-control" value="{{ content.background_video|default('') }}" placeholder="https://example.com/video.mp4">
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Text Color</label>
                    <div class="input-group">
                        <input type="color" name="content[text_color]" class="form-control form-control-color" value="{{ content.text_color|default('#ffffff') }}">
                        <input type="text" class="form-control" value="{{ content.text_color|default('#ffffff') }}">
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Hero Buttons #}
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header border-bottom d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="fa fa-hand-pointer me-2"></i>Action Buttons</h5>
            <button type="button" class="btn btn-sm btn-success" onclick="addHeroButton()">
                <i class="fa fa-plus"></i> Add Button
            </button>
        </div>
        <div class="card-body">
            <small class="text-muted d-block mb-3">Configure the action buttons below the search bar. First button = "FREE TRIAL" style, second = "see more" style.</small>
            <div id="heroButtonsContainer">
                {% for btn in content.buttons|default([]) %}
                <div class="row g-2 mb-2 hero-btn-row">
                    <div class="col-md-2"><input type="text" name="buttons[text][]" class="form-control" value="{{ btn.text|default('') }}" placeholder="Button Text"></div>
                    <div class="col-md-3"><input type="text" name="buttons[url][]" class="form-control" value="{{ btn.url|default('') }}" placeholder="URL"></div>
                    <div class="col-md-2"><input type="color" name="buttons[color][]" class="form-control form-control-color" value="{{ btn.color|default('#3b82f6') }}"></div>
                    <div class="col-md-2"><input type="color" name="buttons[text_color][]" class="form-control form-control-color" value="{{ btn.text_color|default('#ffffff') }}"></div>
                    <div class="col-md-2">
                        <select name="buttons[style][]" class="form-select">
                            <option value="filled" {{ btn.style|default('filled') == 'filled' ? 'selected' : '' }}>Filled (Primary)</option>
                            <option value="outlined" {{ btn.style|default('') == 'outlined' ? 'selected' : '' }}>Outlined (Secondary)</option>
                        </select>
                    </div>
                    <div class="col-md-1"><button type="button" class="btn btn-sm btn-danger w-100" onclick="this.closest('.hero-btn-row').remove()"><i class="fa fa-trash"></i></button></div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Save #}
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-body d-flex justify-content-between">
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="isEnabled" id="isEnabled" {{ section.isEnabled ? 'checked' : '' }}>
                <label class="form-check-label fw-semibold" for="isEnabled">Section Enabled</label>
            </div>
            <button type="submit" class="btn primary px-4"><i class="fa fa-save me-2"></i>Save Changes</button>
        </div>
    </div>
</form>

<script>
function toggleHeroBgType(type) {
    document.querySelector('.hero-bg-color').style.display = type === 'color' ? '' : 'none';
    document.querySelector('.hero-bg-image').style.display = type === 'image' ? '' : 'none';
    document.querySelector('.hero-bg-video').style.display = type === 'video' ? '' : 'none';
}
function addHeroButton() {
    const c = document.getElementById('heroButtonsContainer');
    const r = document.createElement('div');
    r.className = 'row g-2 mb-2 hero-btn-row';
    r.innerHTML = `
        <div class="col-md-2"><input type="text" name="buttons[text][]" class="form-control" placeholder="Text"></div>
        <div class="col-md-3"><input type="text" name="buttons[url][]" class="form-control" placeholder="URL"></div>
        <div class="col-md-2"><input type="color" name="buttons[color][]" class="form-control form-control-color" value="#3b82f6"></div>
        <div class="col-md-2"><input type="color" name="buttons[text_color][]" class="form-control form-control-color" value="#ffffff"></div>
        <div class="col-md-2"><select name="buttons[style][]" class="form-select"><option value="filled">Filled (Primary)</option><option value="outlined">Outlined (Secondary)</option></select></div>
        <div class="col-md-1"><button type="button" class="btn btn-sm btn-danger w-100" onclick="this.closest('.hero-btn-row').remove()"><i class="fa fa-trash"></i></button></div>
    `;
    c.appendChild(r);
}

document.addEventListener('DOMContentLoaded', function() {
    const toggle = document.getElementById('showSearch');
    const settings = document.getElementById('searchBarSettings');
    function updateSearchVisibility() {
        settings.style.display = toggle.checked ? '' : 'none';
    }
    toggle.addEventListener('change', updateSearchVisibility);
    updateSearchVisibility();
});
</script>
{% endblock %}
