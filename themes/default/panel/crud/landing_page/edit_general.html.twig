{% extends '@EasyAdmin/layout.html.twig' %}

{% block content_header_wrapper %}
    <div class="dashboard-header rounded-3 p-4 mb-4 mt-4">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <div class="bg-primary rounded-circle me-3">
                        <i class="fas fa-cog p-3 text-white"></i>
                    </div>
                    <div>
                        <h4 class="mb-1 fw-bold">{{ 'indium.crud.landing_page.edit_section'|trans({'%section%': section.title}) }}</h4>
                        <p class="text-muted mb-0">Configure general site settings</p>
                    </div>
                </div>
                <a href="{{ ea_url({ crudAction: 'index', crudControllerFqcn: 'App\\Core\\Controller\\Panel\\Setting\\LandingPageController' }) }}" class="btn secondary p-3">
                    <i class="fa fa-arrow-left"></i> Back to Sections
                </a>
            </div>
        </div>
    </div>
{% endblock %}

{% block main %}
<form method="post" action="{{ ea_url({ crudAction: 'updateSection', crudControllerFqcn: 'App\\Core\\Controller\\Panel\\Setting\\LandingPageController' }) }}">
    <input type="hidden" name="sectionType" value="{{ section_type }}">

    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header border-bottom">
            <h5 class="mb-0 fw-bold">General Settings</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Site Title</label>
                    <input type="text" name="content[site_title]" class="form-control" value="{{ content.site_title|default('') }}" placeholder="My Game Server Panel">
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Logo URL <small class="text-muted">(leave empty for text)</small></label>
                    <input type="text" name="content[logo_url]" class="form-control" value="{{ content.logo_url|default('') }}" placeholder="/path/to/logo.png">
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Site Description</label>
                    <textarea name="content[site_description]" class="form-control" rows="3" placeholder="A short description of your site">{{ content.site_description|default('') }}</textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Favicon URL</label>
                    <input type="text" name="content[favicon_url]" class="form-control" value="{{ content.favicon_url|default('') }}" placeholder="/favicon.ico">
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-body d-flex justify-content-between">
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="isEnabled" id="isEnabled" {{ section.isEnabled ? 'checked' : '' }}>
                <label class="form-check-label fw-semibold" for="isEnabled">Section Enabled</label>
            </div>
            <button type="submit" class="btn primary px-4">
                <i class="fa fa-save me-2"></i>Save Changes
            </button>
        </div>
    </div>
</form>
{% endblock %}
