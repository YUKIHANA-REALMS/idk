{
    "name": "indium/pterodactyl-addon",
    "description": "Indium Ptero-Addon: Laravel package providing an API interface to the Pterodactyl application API for token creation and SSO authentication",
    "keywords": ["laravel", "pterodactyl", "api", "sso"],
    "type": "laravel-package",
    "license": "MIT",
    "version": "1.0.0",
    "homepage": "https://indium.indicloud.xyz/",
    "authors": [
        {
            "name": "Aryan Dwivedi",
            "email": "aryan@indicloud.xyz",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0|^11.0",
        "firebase/php-jwt": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Indium\\PterodactylAddon\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Indium\\PterodactylAddon\\PterodactylApiAddonServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
